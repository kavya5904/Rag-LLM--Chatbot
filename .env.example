RAG_MODE=ollama

# OpenAI / OpenRouter mode
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Free local embeddings / fallback generation
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
LOCAL_GENERATION_MODEL=google/flan-t5-small
LOCAL_GENERATION_MAX_CONTEXT_CHARS=3500

# Ollama mode for higher-quality free local answers
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=120

DATABASE_URL=sqlite:///./chatbot.db
VECTOR_STORE_DIR=./storage/chroma
UPLOAD_DIR=./storage/uploads
FRONTEND_ORIGIN=http://localhost:5173
